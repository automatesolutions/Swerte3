# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# LLM (premium / Miro)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# OpenAI — daily “Litrato mo Analyze mo” (Images) and “Math mo Analyze mo” (LLM JSON + same Images API)
# Cheapest for Litrato: dall-e-2 + OPENAI_IMAGE_SIZE=256x256. Math cognitive items force 512x512 when model is dall-e-2 for clearer quadrant figures.
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=dall-e-2
OPENAI_IMAGE_SIZE=256x256

# SMS OTP (integrate Twilio/Vonage/etc. in otp_service)
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# PayMongo (₱2 premium)
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=

# GA proxy (optional server-side events)
GA4_MEASUREMENT_ID=

# Optional: require header X-Admin-Key for /internal/ingest
ADMIN_API_KEY=

# Credits per successful PayMongo payment (1 ≈ one ₱2 premium prediction)
PREMIUM_CREDITS_PER_PAYMENT=1
