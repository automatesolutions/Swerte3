# Database
DATABASE_URL=postgresql://swerte3:swerte3@localhost:5432/swerte3

# App
SECRET_KEY=change-me-use-openssl-rand-hex-32
DEBUG=true
# Testing: when DEBUG=true or OTP_TEST_MODE=true, OTP_TEST_CODE is used for /otp/request AND /otp/verify accepts it without a prior request (dev only). Never set in production.
OTP_TEST_CODE=
OTP_TEST_MODE=false
API_CORS_ORIGINS=*

# Google Sheets (Swertres history)
GOOGLE_SHEET_ID=12mVATo7sJTVbvlwEMcOYQwBy8t9LOtGeFlhwaxywCJU
SHEET_TAB_9AM=9AM
SHEET_TAB_4PM=4PM
SHEET_TAB_9PM=9PM

# Column names in CSV (adjust to match your sheet headers)
SHEET_COL_DATE=Date
SHEET_COL_RESULT=Result

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# LLM (premium / Miro)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# OpenAI — daily “Litrato mo Analyze mo” (Images) and “Math mo Analyze mo” (LLM JSON + same Images API)
# Cheapest for Litrato: dall-e-2 + OPENAI_IMAGE_SIZE=256x256. Math cognitive items force 512x512 when model is dall-e-2 for clearer quadrant figures.
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=dall-e-2
OPENAI_IMAGE_SIZE=256x256

# SMS OTP — console | twilio | semaphore (PH-only, https://www.semaphore.co/)
SMS_PROVIDER=console
# Twilio: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Semaphore (Philippines). API key from dashboard; optional registered sender name
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=

# paymongo = PayMongo hosted checkout (typical for PH / testing). paypal = PayPal Orders + in-app capture.
PAYMENT_PROVIDER=paymongo

# PayPal — https://developer.paypal.com → Apps & Credentials (only when PAYMENT_PROVIDER=paypal).
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# MUST match your credentials: Sandbox app → PAYPAL_SANDBOX=true. Live app → false (wrong combo → 401 / checkout 502).
PAYPAL_SANDBOX=true
# HTTPS URLs PayPal redirects the browser to after approve / cancel. Use YOUR public API host + these paths:
#   e.g. ngrok: https://YOUR-SUBDOMAIN.ngrok-free.dev/api/payments/paypal/return
# Free ngrok URLs change when you restart — update PayPal app settings or .env when they do.
PAYPAL_RETURN_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev/api/payments/paypal/return
PAYPAL_CANCEL_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev/api/payments/paypal/cancel
PAYPAL_CURRENCY=PHP

# PayMongo (legacy — leave empty when using PayPal)
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
# Leave empty for mobile: API defaults to swerte3://checkout-done; the app uses expo-web-browser openAuthSession so PayMongo returns into the app.
# Set HTTPS only for non-app clients (e.g. web) — e.g. ngrok pages that link to the app:
# PAYMONGO_CHECKOUT_SUCCESS_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev/api/payments/paymongo/app-success
# PAYMONGO_CHECKOUT_CANCEL_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev/api/payments/paymongo/app-cancel
PAYMONGO_CHECKOUT_SUCCESS_URL=
PAYMONGO_CHECKOUT_CANCEL_URL=
PAYMONGO_SKIP_CAPABILITIES=true

# GA proxy (optional server-side events)
GA4_MEASUREMENT_ID=

# Optional: require header X-Admin-Key for /internal/ingest
ADMIN_API_KEY=

# Credits per successful payment (1 ≈ one ₱2 premium prediction)
PREMIUM_CREDITS_PER_PAYMENT=1
