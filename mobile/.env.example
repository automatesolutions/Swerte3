# Backend (LAN IP for same-Wi‑Fi device, or your Cloud Run URL for staging/production)
# Copy this file to ".env" for local `expo start`. ".env" is gitignored.
#
# EAS Build (eas build) does NOT upload ".env" — the API URL for cloud builds is set in
# eas.json under build.<profile>.env.EXPO_PUBLIC_API_URL (keep it in sync with Cloud Run).
# You can override per build in expo.dev → Environment variables if needed.
# EXPO_PUBLIC_API_URL=https://swerte3-api-xxxxx-as.a.run.app
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional GA4 measurement ID for future Firebase wiring
EXPO_PUBLIC_GA_MEASUREMENT_ID=

# Optional intro video URL (defaults to a short sample MP4 if unset)
# EXPO_PUBLIC_VIDEO_HOME_URL=
